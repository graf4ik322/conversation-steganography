# Conversation Steganography Web Service — Configuration

# === Server ===
PORT=8080
SESSION_SLIDING_TTL=15m
SESSION_MAX_TTL=12h

# === Model Backend ===
# Set to "true" to use OpenRouter API instead of local Python model
OPENROUTER_ENABLED=false

# OpenRouter (only needed if OPENROUTER_ENABLED=true)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Local model (only used if OPENROUTER_ENABLED=false)
LOCAL_MODEL=openai-community/gpt2
LOCAL_DEVICE=cpu
CONVERSATION_STENOGRAPHY_PYTHON=python3

# === Generative Config ===
PROMPT=Continue this casual chat message naturally
TOP_N=5
TEMPERATURE=0.7
FINISH_TOKENS=10
CANDIDATE_POOL=20
CARRIER_TRIALS=3
NATURALNESS_SLACK=0.3
